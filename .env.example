# Qdrant Cloud (free tier: 1GB, 5M tokens/month)
# From https://cloud.qdrant.io → cluster URL and API key
QDRANT_URL=https://your-cluster-url.qdrant.io:6333
QDRANT_API_KEY=your-cluster-api-key
QDRANT_TIMEOUT=60

# Optional: local Qdrant (when QDRANT_URL is unset)
# QDRANT_HOST=localhost
# QDRANT_PORT=6333

# HuggingFace Inference (5M tokens/month free) — text + image embeddings
HF_TOKEN=hf_xxxxxxxx
# HF_TEXT_MODEL=BAAI/bge-m3
# HF_IMAGE_MODEL=openai/clip-vit-base-patch32

# OpenAI Whisper — voice → text (Swiss German); ~$0.006/min
OPENAI_API_KEY=sk-xxx

# Replicate — video keyframes → embeddings (~$0.01/10s clip)
REPLICATE_API_TOKEN=r8_xxx

# Groq — agent reasoning (Mixtral, ~42ms); hackathon demo ~$0.09
GROQ_API_KEY=gsk_xxx
# AGENT_PROVIDER=groq   # or openai | none

# ElevenLabs — German TTS for voice response; ~$0.20/demo, $100 credit
ELEVENLABS_API_KEY=xxx
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# Use HF for query embeddings in production pipeline (default: false)
# USE_EXTERNAL_EMBEDDINGS=true
